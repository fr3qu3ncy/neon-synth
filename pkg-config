#!/bin/bash
# Stub pkg-config for JUCE CMake configure
case "$1" in
    "--modversion"|"--version")
        echo "1.0.0"
        exit 0
        ;;
    "--cflags"|"--cflags-only-I"|"--cflags-only-other")
        # Only return -I flags for cflags
        echo ""
        exit 0
        ;;
    "--libs"|"--libs-only-L"|"--libs-only-other"|"--libs-only-l")
        # Return library flags
        exit 0
        ;;
    "--exists")
        exit 0
        ;;
    "--variable"|"--uninstalled"|"--define-variable")
        echo ""
        exit 0
        ;;
    *)
        exit 0
        ;;
esac
